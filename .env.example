# Copy to .env and fill in. Never commit .env.
# chmod 600 .env

# Plaid API keys (Dashboard -> Developers -> Keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox for testing (user_good/pass_good), production for the free-trial real connections
PLAID_ENV=sandbox

# Server
PORT=8080
HOST=0.0.0.0
# SQLite location. In Docker this lives on the named volume.
DB_PATH=var/expense.db
# Minutes an unlocked session lasts before re-entering the passphrase
SESSION_TTL_MINUTES=60

# --- In-app self-update (production only; leave blank to disable) ---
# Classic PAT with ONLY read:packages (fine-grained PATs don't cover GHCR)
GHCR_TOKEN=
# Image the app compares itself against and watchtower pulls
IMAGE_REF=ghcr.io/ctb3/monthly-expense-helper:latest
# Watchtower sidecar HTTP API (docker-compose.prod.yml service name)
WATCHTOWER_URL=http://watchtower:8080
# Shared secret for watchtower's HTTP API; generate with: openssl rand -hex 32
WATCHTOWER_TOKEN=
